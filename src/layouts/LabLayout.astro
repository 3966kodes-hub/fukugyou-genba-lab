---
/**
 * LabLayout — ラボノート世界観の共通レイアウト
 * (TopBar + Footer + lab.css 読み込み)
 */
import { SITE, NAVIGATION, FOOTER_LINKS } from '../config';
import BaseSEO from '../components/seo/BaseSEO.astro';
import '../styles/lab.css';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  pubDate?: Date;
  updatedDate?: Date;
  noindex?: boolean;
  /** TopBar nav の active 判定に使う category slug（"ai-side-job" 等）または "search" */
  activeNav?: string;
  /** body にさらに付与したい追加クラス（例: "is-top" "is-article"） */
  bodyClass?: string;
}

const {
  title,
  description,
  ogImage,
  ogType = 'website',
  pubDate,
  updatedDate,
  noindex,
  activeNav,
  bodyClass = '',
} = Astro.props;

// ── design-side category metadata for TopBar/Footer ──
const FOOTER_CATS = [
  { slug: 'ai-side-job',     name: 'AI × 副業' },
  { slug: 'getting-started', name: '始め方ガイド' },
  { slug: 'blog-writing',    name: 'ブログ・ライティング' },
  { slug: 'video-audio',     name: '動画・音声' },
  { slug: 'programming',     name: 'プログラミング' },
  { slug: 'investment',      name: '投資・資産運用' },
  { slug: 'real-experience', name: '私もやってみた' },
];
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <BaseSEO
    title={title}
    description={description}
    ogImage={ogImage}
    ogType={ogType}
    pubDate={pubDate}
    updatedDate={updatedDate}
    noindex={noindex}
  />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Zen+Kaku+Gothic+New:wght@400;500;700;900&family=Noto+Sans+JP:wght@400;500;700&display=swap"
    rel="stylesheet"
  />

  <slot name="head" />
</head>

<body class={`lab ${bodyClass}`.trim()}>
  <slot name="before-topbar" />

  <header class="topbar">
    <div class="wrap topbar-inner">
      <a class="brand" href="/" aria-label={SITE.name}>
        <div class="brand-mark">FL</div>
        <div class="brand-name">
          副業現場ラボ
          <small>FUKUGYOU GENBA LAB</small>
        </div>
      </a>
      <nav class="nav" aria-label="メインメニュー">
        {NAVIGATION.map((item) => {
          const slug = item.href.replace(/^\/category\//, '').replace(/\/$/, '');
          return (
            <a href={item.href} class={activeNav === slug ? 'is-active' : ''}>{item.label}</a>
          );
        })}
      </nav>
      <div class="top-tools">
        <a class="search-btn" href="/search/">
          <svg viewBox="0 0 24 24" class="icn" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M20 20l-3.5-3.5"/></svg>
          <span>検索</span>
          <span class="kbd mono">⌘K</span>
        </a>
        <button class="icon-btn" aria-label="メニュー">
          <svg viewBox="0 0 24 24" class="icn" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h12"/></svg>
        </button>
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="wrap footer-grid">
      <div>
        <div class="brand">
          <div class="brand-mark">FL</div>
          <div class="brand-name">副業現場ラボ<small>FUKUGYOU GENBA LAB</small></div>
        </div>
        <p style="margin-top:14px;font-size:12.5px;line-height:1.7;max-width:36ch">
          副業の本当のところを、AI で集めて、たまに自分でも試して、リアルに伝える。
          会社員のための副業情報キュレーション + 実体験ハイブリッドサイト。
        </p>
      </div>
      <div>
        <h4>カテゴリ</h4>
        <ul>
          {FOOTER_CATS.map((c) => (
            <li><a href={`/category/${c.slug}/`}>{c.name}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4>サイト情報</h4>
        <ul>
          {FOOTER_LINKS.map((l) => (
            <li><a href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </div>
    </div>
    <div class="wrap legal">
      <span>© {new Date().getFullYear()} {SITE.name}. All rights reserved.</span>
      <span>※本サイトはアフィリエイト広告（Amazon アソシエイト等）を含みます</span>
    </div>
  </footer>

  <slot name="after-footer" />
</body>
</html>
