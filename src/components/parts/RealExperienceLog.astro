---
import { Icon } from 'astro-icon/components';

export interface Props {
  title?: string;
  date?: string;
  project?: string;
}

const { title = '私もやってみた', date, project } = Astro.props;
---

<aside class="my-6 rounded-xl border-2 p-5" style="border-color: var(--color-warning); background-color: color-mix(in oklab, var(--color-warning) 6%, var(--color-bg));">
  <header class="flex items-start gap-3 mb-3">
    <span class="flex-shrink-0 text-2xl">💡</span>
    <div class="flex-1 min-w-0">
      <p class="font-bold text-base m-0" style="color: var(--color-warning);">{title}</p>
      {(date || project) && (
        <p class="text-xs mt-1 mb-0" style="color: var(--color-muted);">
          {date && <span class="inline-flex items-center gap-1"><Icon name="lucide:calendar" class="w-3 h-3" />{date}</span>}
          {date && project && <span class="mx-2">|</span>}
          {project && <span class="inline-flex items-center gap-1"><Icon name="lucide:folder" class="w-3 h-3" />{project}</span>}
        </p>
      )}
    </div>
  </header>
  <div class="prose prose-sm max-w-none" style="color: var(--color-text);">
    <slot />
  </div>
</aside>
