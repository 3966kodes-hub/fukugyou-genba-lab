---
import type { MarkdownHeading } from 'astro';

export interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const items = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{items.length > 0 && (
  <nav
    aria-label="目次"
    class="toc-nav text-sm sticky top-20 max-h-[calc(100vh-6rem)] overflow-y-auto pr-2"
  >
    <h2
      class="text-xs font-bold tracking-wider uppercase mb-3 pb-2 border-b"
      style="color: var(--color-text-muted); border-color: var(--color-border);"
    >
      📑 目次
    </h2>
    <ul class="space-y-1">
      {items.map((h) => (
        <li class={h.depth === 3 ? 'pl-3' : ''}>
          <a
            href={`#${h.slug}`}
            data-toc-link
            data-target={h.slug}
            class="toc-link block py-1 leading-snug border-l-2 pl-2 transition-colors"
            style="color: var(--color-text-muted); border-color: transparent;"
          >
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .toc-nav :global(.toc-link:hover) {
    color: var(--color-text);
  }
  .toc-nav :global(.toc-link.is-active) {
    color: var(--color-primary);
    font-weight: 600;
    border-color: var(--color-primary) !important;
  }
</style>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('a[data-toc-link]');
  if (links.length > 0) {
    const linkMap = new Map<string, HTMLAnchorElement>();
    links.forEach((link) => {
      const target = link.dataset.target;
      if (target) linkMap.set(target, link);
    });

    const headingEls = Array.from(linkMap.keys())
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => el !== null);

    const setActive = (id: string) => {
      links.forEach((l) => l.classList.remove('is-active'));
      const link = linkMap.get(id);
      if (link) link.classList.add('is-active');
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort(
            (a, b) =>
              a.target.getBoundingClientRect().top -
              b.target.getBoundingClientRect().top,
          );
        if (visible.length > 0) {
          setActive(visible[0].target.id);
        }
      },
      {
        rootMargin: '-80px 0px -70% 0px',
        threshold: 0,
      },
    );

    headingEls.forEach((el) => observer.observe(el));
  }
</script>
