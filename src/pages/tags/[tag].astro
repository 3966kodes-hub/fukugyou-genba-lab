---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../../config';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const tagSet = new Set<string>();
  posts.forEach((p) => p.data.tags.forEach((t) => tagSet.add(t)));

  return Array.from(tagSet).map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`タグ: ${tag}`} description={`タグ「${tag}」が付いた記事一覧`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <nav aria-label="パンくず" class="mb-6 text-sm" style="color: var(--color-text-muted);">
      <a href="/" class="hover:underline">ホーム</a>
      <span class="mx-2">/</span>
      <span>タグ：#{tag}</span>
    </nav>
    <h1 class="mb-6" style="color: var(--color-text);">#{tag}</h1>
    <p class="mb-8 text-sm" style="color: var(--color-text-muted);">{posts.length} 件の記事</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => (
        <a
          href={`/posts/${post.id}/`}
          class="block rounded-lg border overflow-hidden transition-colors hover:bg-[color:var(--color-surface)]"
          style="border-color: var(--color-border);"
        >
          {post.data.heroImage && (
            <img
              src={post.data.heroImage}
              alt={post.data.heroImageAlt ?? post.data.title}
              width="1200"
              height="630"
              loading="lazy"
              decoding="async"
              class="w-full h-auto aspect-[1200/630] object-cover"
              style="background-color: var(--color-surface);"
            />
          )}
          <div class="p-5">
            <p class="text-xs mb-2" style="color: var(--color-text-muted);">
              {post.data.pubDate.toISOString().slice(0, 10)} ・ {CATEGORIES[post.data.category].name}
            </p>
            <h3 class="font-semibold mb-2" style="color: var(--color-text); padding: 0; margin: 0;">
              {post.data.title}
            </h3>
            <p class="text-sm" style="color: var(--color-text-muted);">{post.data.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
