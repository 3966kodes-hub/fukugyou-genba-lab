---
/**
 * 副業現場ラボ — Category listing page (Lab Notebook redesign)
 */
import { getCollection } from 'astro:content';
import LabLayout from '../../layouts/LabLayout.astro';
import { CATEGORIES, type CategorySlug } from '../../config';

export async function getStaticPaths() {
  return Object.keys(CATEGORIES).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params as { slug: CategorySlug };
const category = CATEGORIES[slug];

const posts = (await getCollection('posts', ({ data }) => !data.draft && data.category === slug)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// design-side category tokens (label + colors, matches TOP/article)
const CAT_TOKENS: Record<string, { label: string; c: string; cBg: string }> = {
  'ai-side-job':     { label: 'AI', c: '#0F4F44', cBg: '#DCEFB4' },
  'getting-started': { label: 'ST', c: '#B47A1F', cBg: '#F8E7C2' },
  'blog-writing':    { label: 'WR', c: '#A93B43', cBg: '#F6D4D4' },
  'video-audio':     { label: 'AV', c: '#5840BF', cBg: '#DDD3F4' },
  'creative':        { label: 'CR', c: '#A93B43', cBg: '#F6D4D4' },
  'programming':     { label: 'CD', c: '#1F58BF', cBg: '#CFDDF7' },
  'retail':          { label: 'RT', c: '#B47A1F', cBg: '#F8E7C2' },
  'investment':      { label: '¥¥', c: '#1F8A5B', cBg: '#C8E6D2' },
  'skill-market':    { label: 'SK', c: '#5840BF', cBg: '#DDD3F4' },
  'tools':           { label: 'TL', c: '#5A6573', cBg: '#ECE7D8' },
  'real-experience': { label: 'EX', c: '#11161C', cBg: '#DCD7C5' },
};
const tok = CAT_TOKENS[slug] ?? { label: 'P', c: '#11161C', cBg: '#DCD7C5' };

const fmtDate = (d: Date) => d.toISOString().slice(0, 10);
const idOf = (p: typeof posts[number]) =>
  'P-' + (p.data.pubDate.getTime().toString(36).slice(-3).toUpperCase());
const sourceOf = (p: typeof posts[number]) =>
  p.data.isRealExperience || p.data.category === 'real-experience' ? 'real' : 'ai';
---

<LabLayout
  title={category.name}
  description={category.description}
  activeNav={slug}
  bodyClass="is-list"
>
  <section class="wrap">
    <nav class="breadcrumb mono" aria-label="パンくず">
      <a href="/">HOME</a>
      <span class="sep">/</span>
      <span class="here">カテゴリ：{category.name}</span>
    </nav>

    <header class="list-hero">
      <div class="lh-row">
        <div class="cat-icon-lg" style={`background:${tok.cBg};color:${tok.c}`}>{tok.label}</div>
        <div>
          <div class="eyebrow"><span class="sig"></span>CATEGORY / {slug.toUpperCase()}</div>
          <h1>{category.name}</h1>
          <p class="lede">{category.description}</p>
          <div class="ct">公開記事 {posts.length} 本</div>
        </div>
      </div>
    </header>
  </section>

  <section class="wrap">
    {posts.length === 0 ? (
      <div class="list-empty">このカテゴリの記事は近日公開予定です。</div>
    ) : (
      <div class="list-grid">
        {posts.map((p) => {
          const src = sourceOf(p);
          return (
            <a class="post" href={`/posts/${p.id}/`} style={`--c-bg:${tok.cBg};--c-fg:${tok.c}`}>
              <div class="post-slug">
                <div class="icon">{tok.label}</div>
                <div class="id">{idOf(p)}</div>
              </div>
              <div class="post-body">
                <div class="post-meta">
                  <span class="cat-pill">{category.name}</span>
                  <span>·</span>
                  <span>{fmtDate(p.data.pubDate)}</span>
                  <span style="flex:1"></span>
                  <span class={'ai-mark' + (src === 'real' ? ' is-real' : '')}>
                    {src === 'real' ? '◆ 実体験' : '◇ AIまとめ'}
                  </span>
                </div>
                <h4>{p.data.title}</h4>
                <p class="desc">{p.data.description}</p>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </section>
</LabLayout>
