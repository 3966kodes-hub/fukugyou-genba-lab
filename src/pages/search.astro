---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
---

<BaseLayout title="サイト内検索" description="記事タイトル・本文をキーワードで横断検索">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
    <h1 class="flex items-center gap-2" style="color: var(--color-text);">
      <Icon name="lucide:search" class="w-8 h-8" />
      サイト内検索
    </h1>
    <p class="mb-6" style="color: var(--color-text-muted);">
      記事タイトル・本文をキーワード横断検索できます。
    </p>
    <div id="search" class="pagefind-ui"></div>
  </div>

  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline define:vars={{ }}>
    window.addEventListener('DOMContentLoaded', () => {
      if (typeof PagefindUI === 'undefined') {
        document.getElementById('search').innerHTML =
          '<p style="color: var(--color-text-muted);">検索機能はサイト本番ビルド後に有効になります（ローカルの dev サーバーでは動作しません）。</p>';
        return;
      }
      new PagefindUI({
        element: '#search',
        showSubResults: true,
        translations: {
          placeholder: 'キーワードを入力',
          clear_search: 'クリア',
          load_more: 'さらに表示',
          search_label: '検索',
          filters_label: '絞り込み',
          zero_results: '該当する記事がありません',
          many_results: '[COUNT] 件の記事',
          one_result: '1 件の記事',
          alt_search: '[SEARCH_TERM] では結果がありません。代わりに [DISPLAY_QUERY] で検索しました',
          search_suggestion: '[SEARCH_TERM] では結果なし',
          searching: '検索中...',
        },
      });
    });
  </script>
</BaseLayout>
