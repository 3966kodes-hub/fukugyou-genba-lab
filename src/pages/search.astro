---
/**
 * 副業現場ラボ — Search page (Lab Notebook redesign)
 */
import LabLayout from '../layouts/LabLayout.astro';
---

<LabLayout
  title="サイト内検索"
  description="記事タイトル・本文をキーワードで横断検索"
  activeNav="search"
  bodyClass="is-static"
>
  <link slot="head" rel="stylesheet" href="/pagefind/pagefind-ui.css" />

  <section class="wrap">
    <nav class="breadcrumb mono" aria-label="パンくず">
      <a href="/">HOME</a>
      <span class="sep">/</span>
      <span class="here">サイト内検索</span>
    </nav>

    <header class="list-hero">
      <div class="lh-row">
        <div class="cat-icon-lg" style="background:var(--ink);color:var(--signal)">
          <svg viewBox="0 0 24 24" style="width:24px;height:24px;stroke:currentColor;fill:none;stroke-width:1.8" aria-hidden="true">
            <circle cx="11" cy="11" r="7"/>
            <path d="M20 20l-3.5-3.5"/>
          </svg>
        </div>
        <div>
          <div class="eyebrow"><span class="sig"></span>SEARCH / 全文検索</div>
          <h1>サイト内検索</h1>
          <p class="lede">記事タイトル・本文をキーワードで横断検索できます（Pagefind）。</p>
        </div>
      </div>
    </header>

    <div id="search" class="pagefind-ui"></div>
  </section>

  <script slot="after-footer" is:inline src="/pagefind/pagefind-ui.js"></script>
  <script slot="after-footer" is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      if (typeof PagefindUI === 'undefined') {
        const el = document.getElementById('search');
        if (el) {
          el.innerHTML =
            '<p style="color: var(--ink-3); font-family: var(--font-mono); font-size: 12.5px; padding: 24px; text-align: center;">検索機能はサイト本番ビルド後に有効になります（ローカルの dev サーバーでは動作しません）。</p>';
        }
        return;
      }
      new PagefindUI({
        element: '#search',
        showSubResults: true,
        translations: {
          placeholder: 'キーワードを入力',
          clear_search: 'クリア',
          load_more: 'さらに表示',
          search_label: '検索',
          filters_label: '絞り込み',
          zero_results: '該当する記事がありません',
          many_results: '[COUNT] 件の記事',
          one_result: '1 件の記事',
          alt_search: '[SEARCH_TERM] では結果がありません。代わりに [DISPLAY_QUERY] で検索しました',
          search_suggestion: '[SEARCH_TERM] では結果なし',
          searching: '検索中...',
        },
      });
    });
  </script>
</LabLayout>
